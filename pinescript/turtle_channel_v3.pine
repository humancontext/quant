//@version=5
strategy("Lobster Turtle Channel v3", overlay=true, initial_capital=200, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_type=strategy.commission.percent, commission_value=0.06, pyramiding=3)

// ============================================================
// 🦞 海龟式通道趋势跟踪策略 v3
// 目标：年化 ≥ 60%，回撤 ≤ 20%
//
// 核心改进：
// 1. 双通道系统（快速入场 + 慢速过滤）
// 2. ATR 仓位管理（波动大时小仓，波动小时大仓）
// 3. 金字塔加仓（趋势延续时加仓最多3次）
// 4. 快速出场通道（不等到反向突破，用短周期通道出场）
// 5. 成交量确认
// ============================================================

// ============ 参数 ============
grp_entry = "🚪 入场参数"
fast_len = input.int(15, "入场通道周期", minval=5, maxval=100, group=grp_entry, tooltip="价格创新N周期高/低时入场")
slow_len = input.int(40, "过滤通道周期", minval=10, maxval=200, group=grp_entry, tooltip="只在价格在此通道上方做多/下方做空")

grp_exit = "🚪 出场参数"
exit_len = input.int(10, "出场通道周期", minval=3, maxval=50, group=grp_exit, tooltip="价格跌破N周期低/突破N周期高时平仓（比止损更快出场）")

grp_risk = "🛡️ 风控参数"
atr_len = input.int(20, "ATR 周期", group=grp_risk)
risk_per_trade = input.float(2.0, "每笔风险 %", minval=0.5, maxval=10.0, step=0.5, group=grp_risk, tooltip="每笔交易承担总资金的百分比风险")
sl_atr = input.float(2.0, "止损 ATR 倍数", minval=0.5, maxval=5.0, step=0.1, group=grp_risk)
add_atr = input.float(0.5, "加仓间隔 ATR", minval=0.1, maxval=3.0, step=0.1, group=grp_risk, tooltip="盈利多少ATR后加仓")
max_add = input.int(3, "最大加仓次数", minval=0, maxval=5, group=grp_risk)

grp_filter = "🔍 过滤"
use_vol = input.bool(true, "成交量确认", group=grp_filter)
vol_ma_len = input.int(20, "成交量均线", group=grp_filter)
use_adx = input.bool(true, "ADX 趋势强度过滤", group=grp_filter)
adx_len = input.int(14, "ADX 周期", group=grp_filter)
adx_min = input.int(20, "ADX 最低值", group=grp_filter)

grp_web = "📡 Webhook"
use_wh = input.bool(true, "发送 Webhook", group=grp_web)
wh_secret = input("quant_lobster_2026", "密钥", group=grp_web)

// ============ 指标 ============

// ATR
atr = ta.atr(atr_len)

// 入场通道（Donchian - 含当前K线）
entry_upper = ta.highest(close, fast_len)
entry_lower = ta.lowest(close, fast_len)

// 过滤通道
filter_upper = ta.highest(close, slow_len)
filter_lower = ta.lowest(close, slow_len)

// 出场通道
exit_upper = ta.highest(close, exit_len)
exit_lower = ta.lowest(close, exit_len)

// ADX
[di_p, di_m, adx_val] = ta.dmi(adx_len, adx_len)

// 成交量
vol_ma = ta.sma(volume, vol_ma_len)
vol_ok = not use_vol or volume > vol_ma

// ============ 信号 ============

// 做多条件：close 创 fast_len 新高 + 在慢通道上方 + ADX够强 + 放量
long_entry = close >= entry_upper and close > filter_upper and (not use_adx or adx_val > adx_min) and vol_ok
// 做空条件：close 创 fast_len 新低 + 在慢通道下方 + ADX够强 + 放量
short_entry = close <= entry_lower and close < filter_lower and (not use_adx or adx_val > adx_min) and vol_ok

// 出场：快速通道反向突破
long_exit = close < exit_lower
short_exit = close > exit_upper

// 避免连续信号（每根K线只触发一次）
long_first = long_entry and not long_entry[1]
short_first = short_entry and not short_entry[1]

// ============ 仓位计算 ============

// ATR-based 仓位：risk_per_trade% 的资金 / (sl_atr * ATR)
// 即：每笔亏 risk_per_trade% 的总资金
pos_size = strategy.equity * risk_per_trade / 100 / (sl_atr * atr)
// 限制不超过总资金的 100% 价值
pos_value = pos_size * close
max_value = strategy.equity * 1.0
pos_size := pos_value > max_value ? max_value / close : pos_size

// ============ 状态跟踪 ============

var float last_entry_price = na
var int add_count = 0
var float last_add_price = na

// ============ 绘图 ============

// 入场通道
entry_u_plot = plot(entry_upper, "入场上界", color=color.new(color.blue, 30), linewidth=2)
entry_l_plot = plot(entry_lower, "入场下界", color=color.new(color.blue, 30), linewidth=2)
fill(entry_u_plot, entry_l_plot, color=color.new(color.blue, 93), title="入场通道")

// 出场通道
plot(exit_lower, "出场下界", color=color.new(color.red, 50), linewidth=1, style=plot.style_stepline)
plot(exit_upper, "出场上界", color=color.new(color.green, 50), linewidth=1, style=plot.style_stepline)

// 过滤通道
plot(filter_upper, "过滤上界", color=color.new(color.orange, 70), linewidth=1)
plot(filter_lower, "过滤下界", color=color.new(color.orange, 70), linewidth=1)

// 信号标记
plotshape(long_first, "做多", shape.triangleup, location.belowbar, color.new(color.green, 0), size=size.small, text="L")
plotshape(short_first, "做空", shape.triangledown, location.abovebar, color.new(color.red, 0), size=size.small, text="S")
plotshape(long_exit and strategy.position_size > 0, "平多", shape.xcross, location.abovebar, color.new(color.orange, 0), size=size.tiny)
plotshape(short_exit and strategy.position_size < 0, "平空", shape.xcross, location.belowbar, color.new(color.orange, 0), size=size.tiny)

// ============ 策略执行 ============

// --- 做多逻辑 ---
if long_first and strategy.position_size <= 0
    last_entry_price := close
    add_count := 0
    last_add_price := close
    strategy.entry("Long", strategy.long, qty=pos_size)
    strategy.exit("LongSL", "Long", stop=close - atr * sl_atr)

// 做多加仓
if strategy.position_size > 0 and add_count < max_add and close >= last_add_price + atr * add_atr
    add_count += 1
    last_add_price := close
    strategy.entry("LongAdd" + str.tostring(add_count), strategy.long, qty=pos_size * 0.5)
    strategy.exit("LongSL", "Long", stop=close - atr * sl_atr)

// 多头出场
if long_exit and strategy.position_size > 0
    strategy.close("Long", comment="通道出场")

// --- 做空逻辑 ---
if short_first and strategy.position_size >= 0
    last_entry_price := close
    add_count := 0
    last_add_price := close
    strategy.entry("Short", strategy.short, qty=pos_size)
    strategy.exit("ShortSL", "Short", stop=close + atr * sl_atr)

// 做空加仓
if strategy.position_size < 0 and add_count < max_add and close <= last_add_price - atr * add_atr
    add_count += 1
    last_add_price := close
    strategy.entry("ShortAdd" + str.tostring(add_count), strategy.short, qty=pos_size * 0.5)
    strategy.exit("ShortSL", "Short", stop=close + atr * sl_atr)

// 空头出场
if short_exit and strategy.position_size < 0
    strategy.close("Short", comment="通道出场")

// ============ 信息面板 ============

var table panel = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 70), border_width=1)
if barstate.islast
    table.cell(panel, 0, 0, "入场通道", text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 0, str.tostring(fast_len), text_color=color.blue, text_size=size.small)
    table.cell(panel, 0, 1, "出场通道", text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 1, str.tostring(exit_len), text_color=color.red, text_size=size.small)
    table.cell(panel, 0, 2, "过滤通道", text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 2, str.tostring(slow_len), text_color=color.orange, text_size=size.small)
    table.cell(panel, 0, 3, "ADX", text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 3, str.tostring(adx_val, "#.#"), text_color=adx_val > adx_min ? color.green : color.gray, text_size=size.small)
    table.cell(panel, 0, 4, "ATR", text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 4, str.tostring(atr, "#.#"), text_color=color.white, text_size=size.small)
    
    if strategy.position_size != 0
        dir = strategy.position_size > 0 ? "做多 🟢" : "做空 🔴"
        table.cell(panel, 0, 5, "持仓", text_color=color.white, text_size=size.small)
        table.cell(panel, 1, 5, dir, text_color=strategy.position_size > 0 ? color.green : color.red, text_size=size.small)
        table.cell(panel, 0, 6, "加仓次数", text_color=color.white, text_size=size.small)
        table.cell(panel, 1, 6, str.tostring(add_count), text_color=color.white, text_size=size.small)
        pnl_pct = (close - strategy.position_avg_price) / strategy.position_avg_price * 100 * (strategy.position_size > 0 ? 1 : -1)
        table.cell(panel, 0, 7, "浮盈%", text_color=color.white, text_size=size.small)
        table.cell(panel, 1, 7, str.tostring(pnl_pct, "#.##") + "%", text_color=pnl_pct > 0 ? color.green : color.red, text_size=size.small)

// ============ Webhook ============

if use_wh
    if long_first and strategy.position_size <= 0
        msg = '{"secret":"' + wh_secret + '","symbol":"' + syminfo.ticker + '/USDT","action":"long","price":"' + str.tostring(close) + '","stop_loss":"' + str.tostring(close - atr * sl_atr) + '","take_profit":"' + str.tostring(close + atr * sl_atr * 3) + '","strategy":"turtle_channel_v3","confidence":"' + str.tostring(math.min(adx_val / 50, 1.0), "#.#") + '","timeframe":"' + timeframe.period + '"}'
        alert(msg, alert.freq_once_per_bar_close)
    
    if short_first and strategy.position_size >= 0
        msg = '{"secret":"' + wh_secret + '","symbol":"' + syminfo.ticker + '/USDT","action":"short","price":"' + str.tostring(close) + '","stop_loss":"' + str.tostring(close + atr * sl_atr) + '","take_profit":"' + str.tostring(close - atr * sl_atr * 3) + '","strategy":"turtle_channel_v3","confidence":"' + str.tostring(math.min(adx_val / 50, 1.0), "#.#") + '","timeframe":"' + timeframe.period + '"}'
        alert(msg, alert.freq_once_per_bar_close)
    
    if (long_exit and strategy.position_size > 0) or (short_exit and strategy.position_size < 0)
        dir = strategy.position_size > 0 ? "close_long" : "close_short"
        msg = '{"secret":"' + wh_secret + '","symbol":"' + syminfo.ticker + '/USDT","action":"' + dir + '","price":"' + str.tostring(close) + '","strategy":"turtle_channel_v3_exit","timeframe":"' + timeframe.period + '"}'
        alert(msg, alert.freq_once_per_bar_close)
